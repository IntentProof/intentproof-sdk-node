{
  "name": "intentproof-sdk-node",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "TS_NODE_PREFER_TS_EXTS=true node -r ts-node/register --test tests/*.test.ts",
    "test:coverage": "npm run build && node --experimental-test-coverage --test-coverage-include='dist/**/*.js' --test-coverage-exclude='dist/index.js' --test-coverage-lines=90 --test-coverage-branches=90 --test-coverage-functions=90 -r ts-node/register -r ./tests/preload-dist.cjs --test tests/*.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "type": "commonjs",
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "better-sqlite3": "^12.0.0",
    "json-canonicalize": "^2.0.0",
    "typescript": "^6.0.3",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.7.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "ts-node": "^10.9.2"
  }
}
